<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_currency_rate_tree_inherit_alwatikon_pricing" model="ir.ui.view">
        <field name="name">res.currency.rate.tree.inherit.alwatikon.pricing</field>
        <field name="model">res.currency.rate</field>
        <field name="inherit_id" ref="base.view_currency_rate_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='inverse_company_rate']" position="after">
                <field name="dubai_rate_differential" optional="show"/>
                <field name="dubai_rate" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_currency_form_inherit_alwatikon_pricing" model="ir.ui.view">
        <field name="name">res.currency.form.inherit.alwatikon.pricing</field>
        <field name="model">res.currency</field>
        <field name="inherit_id" ref="base.view_currency_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='rate_ids']/list/field[@name='inverse_company_rate']" position="after">
                <field name="dubai_rate_differential" optional="show"/>
                <field name="dubai_rate" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
