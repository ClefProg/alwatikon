<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_alwatikon_pricing" model="ir.module.category">
        <field name="name">Alwatikon Pricing</field>
        <field name="sequence">50</field>
    </record>

    <record id="res_groups_privilege_pricing_sales" model="res.groups.privilege">
        <field name="name">Sales</field>
        <field name="category_id" ref="module_category_alwatikon_pricing"/>
        <field name="sequence">10</field>
    </record>

    <record id="res_groups_privilege_pricing_accounting" model="res.groups.privilege">
        <field name="name">Accounting</field>
        <field name="category_id" ref="module_category_alwatikon_pricing"/>
        <field name="sequence">20</field>
    </record>

    <record id="group_pricing_sales_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="res_groups_privilege_pricing_sales"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_pricing_accounting_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="res_groups_privilege_pricing_accounting"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="usd_cost_log_company_rule" model="ir.rule">
        <field name="name">USD Cost Log: multi-company</field>
        <field name="model_id" ref="model_usd_cost_log"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
