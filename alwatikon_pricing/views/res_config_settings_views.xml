<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_alwatikon_pricing" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.alwatikon.pricing</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Alwatikon Pricing"
                     data-string="Alwatikon Pricing"
                     name="alwatikon_pricing">

                    <block title="General Ledger Accounts"
                           name="alwatikon_pricing_gl_accounts">
                        <setting string="FX Gain Account"
                                 help="GL account used for foreign-exchange gains."
                                 id="alwatikon_pricing_fx_gain_account_setting">
                            <field name="currency_gain_account_id"/>
                        </setting>
                        <setting string="FX Loss Account"
                                 help="GL account used for foreign-exchange losses."
                                 id="alwatikon_pricing_fx_loss_account_setting">
                            <field name="currency_loss_account_id"/>
                        </setting>
                    </block>

                    <block title="Foreign Exchange"
                           name="alwatikon_pricing_fx">
                        <setting string="FX Journal"
                                 help="Journal used for foreign-exchange revaluation entries."
                                 id="alwatikon_pricing_fx_journal_setting">
                            <field name="fx_journal_id"/>
                        </setting>
                    </block>

                    <block title="Landed Costs"
                           name="alwatikon_pricing_landed">
                        <setting string="Forecast Landed %"
                                 help="Default forecast landed-cost percentage for pricing."
                                 id="alwatikon_pricing_forecast_landed_pct_setting">
                            <field name="forecast_landed_pct"/>
                        </setting>
                    </block>

                    <block title="Opening USD Costs"
                           name="alwatikon_pricing_import">
                        <setting string="Import-Compatible Export Template"
                                 help="Pre-configured export template on Product Variants. Export with External ID, fill current_usd_cost, re-import to update — once per company."
                                 id="alwatikon_pricing_usd_cost_import_template_setting">
                            <div class="mt8 text-muted">
                                <p class="mb-2">
                                    Template name: <strong>Opening USD Cost</strong>
                                    (Inventory → Products → select variants → Action → Export).
                                </p>
                                <ol class="mb-0 ps-3">
                                    <li>Switch to the <strong>target company</strong>.</li>
                                    <li>Open <strong>Product Variants</strong>, select the variants to load.</li>
                                    <li><strong>Action → Export</strong>, enable
                                        <strong>I want to update data (import-compatible export)</strong>.</li>
                                    <li>Template → <strong>Opening USD Cost</strong>
                                        (fields: External ID, Internal Reference, Current USD Cost).</li>
                                    <li>Export, fill <code>current_usd_cost</code> in the spreadsheet.</li>
                                    <li>Re-import the file on <strong>Product Variant</strong>
                                        (External ID column updates existing rows — no Name error).</li>
                                    <li>Repeat for each additional company.</li>
                                </ol>
                            </div>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
