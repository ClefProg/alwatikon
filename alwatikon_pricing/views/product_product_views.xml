<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_product_form_usd_cost" model="ir.ui.view">
        <field name="name">product.product.form.usd.cost</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <field name="usd_currency_id" invisible="1"/>
                <field name="current_usd_cost" widget="monetary" options="{'currency_field': 'usd_currency_id'}"
                       groups="alwatikon_pricing.group_pricing_accounting_admin" />
            </xpath>
        </field>
    </record>
</odoo>
