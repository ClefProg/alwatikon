<?xml version="1.0"?>
<odoo>
    <record id="sh_pos_lot_serial_res_config_settings" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.multi.pricelist</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <block id="pos_interface_section" position="after">
                <div class="sh_pos_multi_pricelist_div" >
                    <h2>POS Pricelist Currency Payment</h2>
                    <div class="row mt16 o_settings_container" >
                        <div class="col-xs-6 col-md-6 o_setting_box" invisible="not pos_use_pricelist">
                            <div class="o_setting_left_pane">
                                <field name="pos_sh_enable_payment_in_pricelist"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="pos_sh_enable_payment_in_pricelist" />
                            </div>
                        </div>
                        <div class="col-xs-6 col-md-6 o_setting_box" >
                            <div class="o_setting_left_pane">
                                <field name="pos_sh_allow_to_change_currency_rate"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="pos_sh_allow_to_change_currency_rate" />
                            </div>
                        </div>
                    </div>
                </div>
            </block>
        </field>
    </record>
</odoo>
